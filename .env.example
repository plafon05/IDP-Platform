COMPOSE_PROJECT_NAME=idp-platform

APP_ENV=development
APP_PORT=8080
DATABASE_URL=postgres://idp:idp@postgres:5432/idp?sslmode=disable
REDIS_URL=redis://redis:6379
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=local-development-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
REFRESH_COOKIE_NAME=idp_refresh_token
IDP_AUTOCOMPLETE_INTERVAL=1h
SEED_ADMIN_EMAIL=admin@idp.local
SEED_ADMIN_PASSWORD=Admin12345
SEED_ADMIN_FIRST_NAME=HR
SEED_ADMIN_LAST_NAME=Admin

BACKEND_IMAGE=idp-platform-backend:local
FRONTEND_IMAGE=idp-platform-frontend:local

BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_DB=idp
POSTGRES_USER=idp
POSTGRES_PASSWORD=idp

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=idp-platform
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false
