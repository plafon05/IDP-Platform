COMPOSE_PROJECT_NAME=idp-platform-prod

# Public deployment
PUBLIC_URL=
TLS_CERT_DIR=

# Images built and published by CI/CD
BACKEND_IMAGE=
FRONTEND_IMAGE=

# PostgreSQL
POSTGRES_DB=idp
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis. REDIS_URL must contain the URL-encoded password.
REDIS_PASSWORD=
REDIS_URL=

# JWT signing keys: current key first, validation-only keys after it.
JWT_SECRETS=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
REFRESH_COOKIE_NAME=idp_refresh_token

# Object storage
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=idp-platform

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=IDP Platform
EMAIL_QUEUE_KEY=idp:email:queue
EMAIL_REMINDER_TIMEZONE=Europe/Moscow
