COMPOSE_PROJECT_NAME=idp-platform-prod

PUBLIC_URL="Публичный HTTPS-адрес приложения"
TLS_CERT_DIR="Путь к папке с fullchain.pem и privkey.pem"

BACKEND_IMAGE="Адрес production-образа backend"
FRONTEND_IMAGE="Адрес production-образа frontend"

POSTGRES_DB=idp
POSTGRES_USER="Пользователь PostgreSQL"
POSTGRES_PASSWORD="Пароль пользователя PostgreSQL"
DATABASE_URL="Строка подключения PostgreSQL"

REDIS_PASSWORD="Пароль Redis"
REDIS_URL="Строка подключения Redis"

JWT_SECRETS="Ключи JWT в формате current:secret,previous:old-secret"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
REFRESH_COOKIE_NAME=idp_refresh_token

MINIO_ROOT_USER="Пользователь MinIO"
MINIO_ROOT_PASSWORD="Пароль пользователя MinIO"
MINIO_ACCESS_KEY="Отдельный ключ приложения с доступом только к бакету"
MINIO_SECRET_KEY="Секрет отдельного ключа приложения"
MINIO_BUCKET=idp-platform

SMTP_HOST="Адрес SMTP-сервера"
SMTP_PORT=587
SMTP_USERNAME="Пользователь SMTP, если требуется"
SMTP_PASSWORD="Пароль SMTP, если требуется"
SMTP_FROM_EMAIL="Email отправителя уведомлений"
SMTP_FROM_NAME=IDP Platform
EMAIL_QUEUE_KEY=idp:email:queue
EMAIL_REMINDER_TIMEZONE=Europe/Moscow
